      "parameters": {
        "jsCode": "// Obtener el item de entrada\nconst inputData = $input.first().json;\n\nlet rawText = {};\n\ntry {\n  // En n8n, inputData ya es el objeto raíz. Navegamos directo al \"text\"\n  if (inputData.output && inputData.output[0] && inputData.output[0].content && inputData.output[0].content[0]) {\n    rawText = inputData.output[0].content[0].text || {};\n  } else if (Array.isArray(inputData) && inputData[0].output) {\n    // Por si acaso viene envuelto en un array adicional\n    rawText = inputData[0].output[0].content[0].text || {};\n  }\n\n  // Si por alguna razón la IA lo devolviera como string en el futuro, lo parseamos\n  if (typeof rawText === 'string') {\n    rawText = JSON.parse(rawText);\n  }\n} catch(e) {\n  console.log(\"Error extrayendo el JSON:\", e);\n  rawText = {};\n}\n\n// --- Extraer secciones ---\nconst ident  = rawText['Identificación']            || {};\nconst ubic   = rawText['Ubicación']                 || {};\nconst clasif = rawText['Clasificación y Actividades'] || {};\nconst meta   = rawText['Metadatos']                 || {};\n\n// --- Helpers ---\nconst cleanStr = (val) => (val != null && val !== '') ? String(val).trim().toUpperCase() : '';\n\n// --- Tipo de persona ---\nconst tipoRaw    = String(ident['24'] || '').toLowerCase();\nconst tipoPersona = (tipoRaw.includes('natural') || tipoRaw.trim() === '2') ? 'Natural' : 'Jurídica';\n\n// --- Documento e identificación ---\nconst tipoDoc = String(ident['25'] || '').toLowerCase();\nconst nit     = String(ident['5']  || '').trim();\nconst dv      = String(ident['6']  || '').trim();\nlet   nroId   = String(ident['26'] || '').trim();\n\nif (tipoDoc.includes('ciudadan')) {\n  if (nroId.length === 11) nroId = nroId.slice(0, 10);\n  else if (nroId.length === 12) nroId = nroId.slice(1, 11);\n}\n\n// --- Nombre completo ---\nlet nombreCompleto = '';\nif (tipoPersona === 'Natural') {\n  nombreCompleto = [\n    cleanStr(ident['33']),\n    cleanStr(ident['34']),\n    cleanStr(ident['31']),\n    cleanStr(ident['32']),\n  ].filter(Boolean).join(' ');\n} else {\n  nombreCompleto = cleanStr(ident['35']);\n}\n\n// --- Actividades económicas ---\nconst actividades = [];\nif (clasif['46']) actividades.push({ tipo: 'principal',  codigo: clasif['46'], fecha_inicio: clasif['47'] || null });\nif (clasif['48']) actividades.push({ tipo: 'secundaria', codigo: clasif['48'], fecha_inicio: clasif['49'] || null });\nif (clasif['50']) actividades.push({ tipo: 'otras',      codigo: clasif['50'], fecha_inicio: null });\n\n// --- Resultado base ---\nconst resultado = {\n  tipo_persona:          tipoPersona,\n  tipo_documento:        cleanStr(ident['25']),\n  nit,\n  dv,\n  numero_identificacion: nroId,\n  nombre_completo:       nombreCompleto,\n  email:                 String(ubic['42'] || '').toLowerCase().trim(),\n  telefono:              String(ubic['44'] || '').trim(),\n  direccion:             cleanStr(ubic['41']),\n  ciudad:                cleanStr(ubic['40']),\n  departamento:          cleanStr(ubic['39']),\n  pais:                  cleanStr(ubic['38']),\n  codigo_postal:         String(ubic['43'] || '').trim(),\n  responsabilidades:     rawText['Responsabilidades'] || [],\n  actividades_economicas: actividades,\n  metadata: {\n    formulario: meta['Número de formulario']            || null,\n    fecha_pdf:  meta['Fecha generación documento PDF']  || null,\n  }\n};\n\n// --- Campos extra para Jurídica ---\nif (tipoPersona === 'Jurídica') {\n  resultado.nombre_comercial    = cleanStr(ident['36']);\n  resultado.sigla               = cleanStr(ident['37']);\n  resultado.num_establecimientos = clasif['52'] || null;\n}\n\nreturn [{ json: resultado }];"
      },
